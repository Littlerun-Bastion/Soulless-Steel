[node name="LivingWorldTest" type="Node2D"]
script = ExtResource("1_root")

[node name="Map" parent="." instance=ExtResource("3_map")]

; SpawnZones spread across the big_map's 20k×20k area (corners at ±10000).
; Kept well inside the boundary so jitter doesn't push them out of nav.
[node name="SpawnZones" type="Node2D" parent="."]

[node name="Spawn_N" type="Marker2D" parent="SpawnZones"]
position = Vector2(0, -9000)

[node name="Spawn_S" type="Marker2D" parent="SpawnZones"]
position = Vector2(0, 9000)

[node name="Spawn_W" type="Marker2D" parent="SpawnZones"]
position = Vector2(-9000, 0)

[node name="Spawn_E" type="Marker2D" parent="SpawnZones"]
position = Vector2(9000, 0)

[node name="Spawn_NE" type="Marker2D" parent="SpawnZones"]
position = Vector2(8000, -8000)

[node name="Spawn_NW" type="Marker2D" parent="SpawnZones"]
position = Vector2(-8000, -8000)

[node name="Spawn_SE" type="Marker2D" parent="SpawnZones"]
position = Vector2(8000, 8000)

[node name="Spawn_SW" type="Marker2D" parent="SpawnZones"]
position = Vector2(-8000, 8000)

[node name="Exits" type="Node2D" parent="."]

[node name="Exit_N" parent="Exits" instance=ExtResource("4_exit")]
position = Vector2(0, -9500)

[node name="Exit_S" parent="Exits" instance=ExtResource("4_exit")]
position = Vector2(0, 9500)

[node name="Exit_E" parent="Exits" instance=ExtResource("4_exit")]
position = Vector2(9500, 0)

[node name="Exit_W" parent="Exits" instance=ExtResource("4_exit")]
position = Vector2(-9500, 0)

; In-match visual feedback containers (mirrors Arena's structure).
; Particles and one-shot effects get spawned under these at runtime.
[node name="Casings" type="Node2D" parent="."]
script = ExtResource("6_casings_script")
casing = ExtResource("7_casing")
casings_count = 500

[node name="Mechas" type="Node2D" parent="."]

[node name="ScrapParts" type="Node2D" parent="."]

[node name="Projectiles" type="Node2D" parent="."]

[node name="Trails" type="Node2D" parent="."]

[node name="Flashes" type="Node2D" parent="."]

[node name="Smoke" type="Node2D" parent="."]

[node name="Explosions" type="Node2D" parent="."]

[node name="HeatmapEffects" parent="." instance=ExtResource("8_heatmap")]

[node name="PlayerHUD" parent="." instance=ExtResource("5_hud")]

[node name="GameOver" parent="." instance=ExtResource("10_gameover")]

[node name="PauseMenu" parent="." instance=ExtResource("9_pause")]

; Periodic ambient wind sound timer (currently a stub).
[node name="WindsTimer" type="Timer" parent="."]
wait_time = 20.0
autostart = true

; Entrance animation. AI mechas stay paused until this animation_ending signal
; fires (see _on_IntroAnimation_animation_ending in script).
[node name="Intro" type="CanvasLayer" parent="."]
layer = 2

[node name="IntroAnimation" parent="Intro" instance=ExtResource("11_intro")]

[node name="Director" type="Node" parent="."]
script = ExtResource("2_director")

[connection signal="pause_toggle" from="PauseMenu" to="." method="_on_PauseMenu_pause_toggle"]
[connection signal="timeout" from="WindsTimer" to="." method="_on_WindsTimer_timeout"]
[connection signal="animation_ending" from="Intro/IntroAnimation" to="." method="_on_IntroAnimation_animation_ending"]
